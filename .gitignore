# Node.js 의존성 폴더
# 이 한 줄이 944개의 파일을 숨겨줍니다!
node_modules/

# 로그 파일 (불필요한 기록 파일)
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 운영체제 생성 파일 (macOS, Windows)
.DS_Store
Thumbs.db

# 환경 변수 파일 (매우 중요!)
# API 키, 데이터베이스 비밀번호 등 민감 정보를 저장하는 파일입니다.
# 절대로 Git에 올리면 안 됩니다.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local